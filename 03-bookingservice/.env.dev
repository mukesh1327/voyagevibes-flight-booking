APP_ENV=dev
PORT=8083
SERVER_SSL_ENABLED=false
ConnectionStrings__BookingDb=Server=localhost,1433;Database=booking_service_db;User Id=sa;Password=RedHat#123;TrustServerCertificate=True
KAFKA__ENABLED=true
KAFKA__BOOTSTRAPSERVERS=localhost:9092
KAFKA__BOOKINGEVENTSTOPIC=booking.events
KAFKA__INVENTORYEVENTSTOPIC=flight.inventory.events
KAFKA__PAYMENTEVENTSTOPIC=payment.events
KAFKA__CONSUMERGROUPID=booking-service-dev
KAFKA__AUTOOFFSETRESET=latest
KAFKA__ENSURETOPICS=true
KAFKA__TOPICPARTITIONS=1
KAFKA__TOPICREPLICATIONFACTOR=1
KAFKA__MISSINGTOPICRETRYDELAYMS=2000
EXTERNALSERVICES__FLIGHT__BASEURL=https://flight.voyagevibes.in:8082
EXTERNALSERVICES__FLIGHT__ALLOWINSECURETLS=true
EXTERNALSERVICES__FLIGHT__TIMEOUTSECONDS=8

# OpenTelemetry
OTEL_ENABLED=false
OTEL_SDK_DISABLED=true
OTEL_SERVICE_NAME=booking-service
OTEL_RESOURCE_ATTRIBUTES=service.namespace=voyagevibes,service.instance.id=booking-service-dev
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
